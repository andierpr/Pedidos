generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User { 
  id    String @id @default(uuid()) // 🔹 chave primária
  name  String
  email String @unique
  password String
  cep String
  admin Boolean @default(false) 

}

model Product {
  id String @id @default(cuid())  // 🔹 chave primária
  name String
  description String
  price Int
  category String
  img String
  createdAt DateTime @default(now())

}



